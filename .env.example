# Copy file ini menjadi ".env" (tanpa .example) lalu isi nilai asli Anda.
#   cp .env.example .env
#
# JANGAN commit file ".env" (sudah ada di .gitignore) -- file ini mengandung
# secret. Yang aman untuk di-commit hanya ".env.example" ini sebagai template.

# === WAJIB ===
OPENAI_API_KEY=sk-your-api-key-here

# === OPSIONAL (default sudah masuk akal, override hanya kalau perlu) ===

# Model reasoning utama dan fallback kalau model utama gagal/tidak tersedia.
# OPENAI_MODEL=gpt-5.5
# OPENAI_MODEL_FALLBACK=gpt-5.1

# Path ke binary scanner eksternal, kalau tidak ada di PATH standar.
# SLITHER_BIN=slither
# SEMGREP_BIN=semgrep
# FORGE_BIN=forge

# Ruleset Semgrep registry tambahan (di luar custom rules di rules/).
# SEMGREP_RULESETS=p/security-audit,p/owasp-top-ten,p/secrets

# Path kerja (clone repo sementara) dan output report.
# BBAI_WORKDIR=./workdir
# BBAI_REPORTS_DIR=./reports

# Path database SQLite untuk menyimpan riwayat scan.
# BBAI_DB_PATH=./storage/findings.db

# Qdrant vector DB (opsional, belum aktif di pipeline -- lihat
# storage/vector_store.py). Kosongkan/hapus baris ini kalau tidak dipakai.
# QDRANT_URL=

# Timeout eksekusi tool eksternal (detik).
# BBAI_TOOL_TIMEOUT=600
