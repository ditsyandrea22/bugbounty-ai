# Copy file ini menjadi ".env" (tanpa .example) lalu isi nilai asli Anda.
#   cp .env.example .env
#
# JANGAN commit file ".env" (sudah ada di .gitignore) -- file ini mengandung
# secret. Yang aman untuk di-commit hanya ".env.example" ini sebagai template.

# === WAJIB ===
OPENAI_API_KEY=sk-your-api-key-here

# === Memakai router/proxy OpenAI-compatible (TokenRouter, OpenRouter, dst) ===
# Kosongkan/hapus OPENAI_BASE_URL untuk memakai OpenAI resmi langsung.
# Untuk TokenRouter, isi seperti contoh ini (sesuaikan dengan endpoint Anda):
# OPENAI_BASE_URL=https://api.tokenrouter.com/v1
#
# Kalau pakai router, OPENAI_MODEL harus diisi dengan nama model SESUAI
# yang dikenali router Anda (bukan nama OpenAI asli seperti "gpt-5.5"),
# contoh: OPENAI_MODEL=claude-opus-4-7 atau OPENAI_MODEL=kimi-k2p6
# -- cek dashboard/dokumentasi router Anda untuk daftar model ID yang valid.
OPENAI_MODEL=gpt-5.5
# OPENAI_BASE_URL=

# Fallback model HANYA relevan kalau memakai OpenAI resmi (base_url kosong)
# dengan nama model OpenAI asli. Kalau memakai router dengan model custom,
# KOSONGKAN baris ini (hapus atau set string kosong) -- nama fallback
# OpenAI asli tidak akan dikenali router Anda dan fallback akan gagal lagi
# dengan error baru, bukan membantu.
OPENAI_MODEL_FALLBACK=gpt-5.1

# === OPSIONAL LAINNYA (default sudah masuk akal, override hanya kalau perlu) ===

# Path ke binary scanner eksternal, kalau tidak ada di PATH standar.
# SLITHER_BIN=slither
# SEMGREP_BIN=semgrep
# FORGE_BIN=forge

# Ruleset Semgrep registry tambahan (di luar custom rules di rules/).
# SEMGREP_RULESETS=p/security-audit,p/owasp-top-ten,p/secrets

# Path kerja (clone repo sementara) dan output report.
# BBAI_WORKDIR=./workdir
# BBAI_REPORTS_DIR=./reports

# Path database SQLite untuk menyimpan riwayat scan.
# BBAI_DB_PATH=./storage/findings.db

# Qdrant vector DB (opsional, belum aktif di pipeline -- lihat
# storage/vector_store.py). Kosongkan/hapus baris ini kalau tidak dipakai.
# QDRANT_URL=

# Timeout eksekusi tool eksternal (detik).
# BBAI_TOOL_TIMEOUT=600

# Auto-install dependency repo target (forge install / npm install) kalau
# terdeteksi hilang sebelum Slither dijalankan. DEFAULT MATI (false).
# PERINGATAN: ini mengeksekusi script dari repo target yang belum tepercaya
# (npm postinstall hooks, forge install scripts) -- hanya aktifkan untuk
# repo yang Anda PERCAYA atau sudah ditinjau, bukan untuk scan sembarangan
# target bug bounty yang tidak dikenal.
# BBAI_AUTO_INSTALL_DEPS=false
